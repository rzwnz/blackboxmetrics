# ──────────────────────────────────────────────────────────────────────────────
# Black Box Metrics – Environment Variables
# Copy this file as .env and fill in real values before deployment.
# ──────────────────────────────────────────────────────────────────────────────

# ── S3 / Garage Exporter ─────────────────────────────────────────────────────
S3_ENDPOINT=http://garage:3900
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_BUCKET=*
S3_REGION=garage

# ── Tomcat Exporter ──────────────────────────────────────────────────────────
TOMCAT_URL=http://tomcat:8080
TOMCAT_STATUS_PATH=/manager/status/all?XML=true
TOMCAT_USER=admin
TOMCAT_PASSWORD=changeme

# ── Dump Script ──────────────────────────────────────────────────────────────
VM_URL=http://localhost:8428
LOGS_DIR=/var/log/tandem
OUTPUT_DIR=./dumps
