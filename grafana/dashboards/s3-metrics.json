{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Bucket Availability",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } }
          ]
        }
      },
      "targets": [
        {
          "expr": "s3_bucket_up",
          "legendFormat": "{{bucket}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Objects per Bucket",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "s3_bucket_objects_total",
          "legendFormat": "{{bucket}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Bucket Size",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "s3_bucket_size_bytes",
          "legendFormat": "{{bucket}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Largest Object per Bucket",
      "type": "bargauge",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 104857600 },
              { "color": "red", "value": 1073741824 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "s3_bucket_largest_object_bytes",
          "legendFormat": "{{bucket}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Size Growth Rate",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "rate(s3_bucket_size_bytes[1h])",
          "legendFormat": "{{bucket}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Object Count Change Rate",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 0, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "rate(s3_bucket_objects_total[1h])",
          "legendFormat": "{{bucket}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Exporter Scrape Duration",
      "type": "timeseries",
      "gridPos": { "h": 6, "w": 12, "x": 12, "y": 18 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "s3_exporter_scrape_duration_seconds",
          "legendFormat": "Scrape Duration",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Exporter Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "s3_exporter_scrape_errors_total",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": ["s3", "storage", "tandem"],
  "templating": {
    "list": [
      {
        "name": "DS_VICTORIAMETRICS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "VictoriaMetrics", "value": "VictoriaMetrics" }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "S3 Storage Metrics",
  "uid": "s3-metrics",
  "version": 1
}
