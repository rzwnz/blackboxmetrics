{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Tomcat Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "1": { "text": "UP", "color": "green" } } },
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } }
          ]
        }
      },
      "targets": [
        {
          "expr": "tomcat_up",
          "legendFormat": "Tomcat",
          "refId": "A"
        }
      ]
    },
    {
      "title": "JVM Heap Usage",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.7 },
              { "color": "red", "value": 0.9 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "1 - (tomcat_jvm_memory_free_bytes / tomcat_jvm_memory_total_bytes)",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Requests",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "targets": [
        {
          "expr": "sum(tomcat_connector_request_count_total)",
          "legendFormat": "Requests",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Total Errors",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(tomcat_connector_error_count_total)",
          "legendFormat": "Errors",
          "refId": "A"
        }
      ]
    },
    {
      "title": "JVM Memory",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "tomcat_jvm_memory_max_bytes",
          "legendFormat": "Max",
          "refId": "A"
        },
        {
          "expr": "tomcat_jvm_memory_total_bytes",
          "legendFormat": "Total (allocated)",
          "refId": "B"
        },
        {
          "expr": "tomcat_jvm_memory_total_bytes - tomcat_jvm_memory_free_bytes",
          "legendFormat": "Used",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Thread Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "tomcat_connector_thread_max",
          "legendFormat": "Max ({{connector}})",
          "refId": "A"
        },
        {
          "expr": "tomcat_connector_thread_count",
          "legendFormat": "Count ({{connector}})",
          "refId": "B"
        },
        {
          "expr": "tomcat_connector_thread_busy",
          "legendFormat": "Busy ({{connector}})",
          "refId": "C"
        }
      ]
    },
    {
      "title": "Request Count (rate)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "rate(tomcat_connector_request_count_total[5m])",
          "legendFormat": "{{connector}}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "rate(tomcat_connector_error_count_total[5m])",
          "legendFormat": "Errors ({{connector}})",
          "refId": "A"
        },
        {
          "expr": "rate(tomcat_connector_error_count_total[5m]) / rate(tomcat_connector_request_count_total[5m])",
          "legendFormat": "Error % ({{connector}})",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Network I/O (Bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "Bps",
          "custom": { "fillOpacity": 15, "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "rate(tomcat_connector_bytes_received_total[5m])",
          "legendFormat": "Received ({{connector}})",
          "refId": "A"
        },
        {
          "expr": "-rate(tomcat_connector_bytes_sent_total[5m])",
          "legendFormat": "Sent ({{connector}})",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Processing Time (avg request latency)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "custom": { "fillOpacity": 10, "lineWidth": 2 }
        }
      },
      "targets": [
        {
          "expr": "rate(tomcat_connector_processing_time_ms_total[5m]) / rate(tomcat_connector_request_count_total[5m])",
          "legendFormat": "Avg Latency ({{connector}})",
          "refId": "A"
        },
        {
          "expr": "tomcat_connector_max_time_ms",
          "legendFormat": "Max Time ({{connector}})",
          "refId": "B"
        }
      ]
    },
    {
      "title": "Memory Pools",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": { "fillOpacity": 10, "lineWidth": 1 }
        }
      },
      "targets": [
        {
          "expr": "tomcat_memory_pool_usage_bytes",
          "legendFormat": "{{pool}} ({{type}})",
          "refId": "A"
        }
      ]
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": ["tomcat", "jvm", "tandem"],
  "templating": {
    "list": [
      {
        "name": "DS_VICTORIAMETRICS",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "VictoriaMetrics", "value": "VictoriaMetrics" }
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Tomcat Application Metrics",
  "uid": "tomcat-metrics",
  "version": 1
}
